# Ignore everything in the repository by default
/*

# Keep this .gitignore file
!/.gitignore

# Allow the backend and its contents
!/backend/
!/backend/**

# Allow the frontend and its contents
!/frontend/
!/frontend/**

# (Optional) If you later want to keep other files like README.md or .github,
# add explicit exceptions here, e.g.:
#!/README.md
#!/.github/
